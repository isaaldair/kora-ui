{
  "name": "kora-ui",
  "version": "0.4.0",
  "description": "React UI component library styled with Tailwind CSS. Ships primitives + 6 opinionated themes (default, vintage, futuristic, electric, oceanic, botanical).",
  "author": {
    "name": "Isaac Avila",
    "email": "isaacaldairavila@gmail.com",
    "url": "https://github.com/isaaldair"
  },
  "license": "MIT",
  "homepage": "https://kora-ui.istmocode.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaldair/kora-ui.git"
  },
  "bugs": {
    "url": "https://github.com/isaaldair/kora-ui/issues"
  },
  "keywords": [
    "react",
    "react-components",
    "ui",
    "ui-library",
    "component-library",
    "design-system",
    "tailwind",
    "tailwindcss",
    "typescript",
    "themes",
    "palette",
    "design-tokens",
    "kora",
    "kora-ui"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./styles/themes.css": "./src/styles/themes.css",
    "./styles/themes.json": "./src/styles/themes.json",
    "./styles/*": "./src/styles/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup && node ./scripts/prepend-use-client.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "canvas-confetti": "^1.9.4",
    "emoji-picker-react": "^4.18.0",
    "html5-qrcode": "^2.3.8",
    "imask": "^7.6.1",
    "libphonenumber-js": "^1.12.41",
    "qrcode": "^1.5.4",
    "react-day-picker": "^9.14.0",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.6.0",
    "react-pdf": "^10.4.1",
    "signature_pad": "^5.1.3"
  }
}
