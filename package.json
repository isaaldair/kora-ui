{
  "name": "kora-ui",
  "version": "0.0.1",
  "description": "React UI component library styled with Tailwind CSS.",
  "author": {
    "name": "Isaac Avila",
    "email": "isaacaldairavila@gmail.com",
    "url": "https://github.com/isaaldair"
  },
  "license": "MIT",
  "homepage": "https://github.com/isaaldair/kora-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaldair/kora-ui.git"
  },
  "bugs": {
    "url": "https://github.com/isaaldair/kora-ui/issues"
  },
  "keywords": [
    "react",
    "react-components",
    "ui",
    "ui-library",
    "component-library",
    "design-system",
    "tailwind",
    "tailwindcss",
    "typescript",
    "kora",
    "kora-ui"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
