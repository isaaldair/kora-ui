{
  "name": "kora-ui-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the kora-ui component library and its docs site.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w kora-ui",
    "build:lib": "npm run build -w kora-ui",
    "build:docs": "npm run build -w docs",
    "dev:lib": "npm run dev -w kora-ui",
    "dev:docs": "npm run dev -w docs",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
